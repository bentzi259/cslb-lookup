# Data source: "csv" (default) or "firecrawl"
DATA_SOURCE=csv

# Path to SQLite database
DATABASE_PATH=data/licenses.db

# Firecrawl API key (required when using firecrawl source)
FIRECRAWL_API_KEY=

# CSLB Data Portal URL
CSLB_DATA_PORTAL_URL=https://www.cslb.ca.gov/onlineservices/dataportal/ContractorList
